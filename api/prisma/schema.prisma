generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model translations {
  id           String @id @default(uuid()) @db.Uuid
  abbreviation String
  name         String
  method       String
  language     String
  year         Int
}

model books {
  id            String @id @default(uuid()) @db.Uuid
  translationId String @db.Uuid
  title         String
  number        Int
}

model chapters {
  id     String @id @default(uuid()) @db.Uuid
  bookId String @db.Uuid
  title  String
  number Int
}

model verses {
  id          String @id @default(uuid()) @db.Uuid
  chapterId   String @db.Uuid
  type        String
  number      Int
  headingText String
}