generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model translations {
  id           String @id @default(uuid()) @db.Uuid
  abbreviation String
  name         String
  method       String
  language     String
  year         Int
}

model books {
  id            String @id @default(uuid()) @db.Uuid
  translationId String @db.Uuid
  title         String
  number        Int
}